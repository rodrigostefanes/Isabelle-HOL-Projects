theory RankLuiz

imports Main "HOL-Library.FuncSet" HOL.List

begin

section \<open>Representations of numbers in a basis\label{ch:document-prep}\<close>

text \<open>
 In this section, we implement representations of numbers in an arbitrary basis q

  Function little_endian_rep l q n represents n in basis q with length l
 \<close>

fun little_endian_rep :: "nat \<Rightarrow> nat  \<Rightarrow> nat list" where
    "little_endian_rep 0 n = []"
  | "little_endian_rep (Suc 0) n = []"
  | "little_endian_rep q 0 = []"
  | "little_endian_rep q n = (n mod q) # little_endian_rep q (n div q)"

fun little_endian_value :: "nat \<Rightarrow> nat list \<Rightarrow> nat" where
    "little_endian_value q [] = 0"
  | "little_endian_value q (x#xs) = x + q*(little_endian_value q xs)"

theorem value_rep:
  assumes q_valid: "q\<ge>2"
  shows "little_endian_value q (little_endian_rep q n) = n"
proof (induction n rule: less_induct)
  case (less n)
  then show ?case
  proof (cases "n=0")
    case True
    have 1: "little_endian_rep q n = little_endian_rep q 0" by (simp add: True)
    have 2: "little_endian_rep q 0 = []" using q_valid by (metis Suc_1 add_Suc less_eqE little_endian_rep.simps(3) numeral_1_eq_Suc_0
          one_eq_numeral_iff)
    have 3: "little_endian_rep q n = []" using 1 and 2 by simp
    have 4: ?thesis using 3 by (simp add: True)
    show ?thesis by (simp add: "4")
  next
    case n_not_zero: False
    assume 5: "(\<And>y. y < n \<Longrightarrow> little_endian_value q (little_endian_rep q y) = y)"
    have 6: "little_endian_rep q n = (n mod q) # little_endian_rep q (n div q)" using q_valid and n_not_zero by (metis lessI linorder_not_less little_endian_rep.elims numeral_2_eq_2 zero_less_Suc)
    have 7: "n div q<n" using q_valid and n_not_zero by simp
    have 8: "little_endian_value q (little_endian_rep q (n div q)) = n div q" using 5 and 7 by simp
    show ?thesis by (simp add: "6" "8")
  qed
qed
  
text \<open>
  To have a bijection between numbers and lists, we need to assume that the lists are comprised of
  numbers between 0 and q-1, and have no trailing zeroes
\<close>

definition list_represents_number_in_base :: "nat list \<Rightarrow> nat \<Rightarrow> bool" where
  "list_represents_number_in_base l q \<equiv> (q\<ge>2) \<and> (\<forall> i. ( i< length l \<longrightarrow> (l! i <q)) )\<and> (l \<noteq> [] \<longrightarrow> (last l)\<noteq>0)"

lemma valid_tail:
  assumes "list_represents_number_in_base (a # l) q"
  shows   "list_represents_number_in_base l q"
proof -
  have q2: "q \<ge> 2"
    and digits: "\<forall>i<length (a#l). (a#l)!i < q"
    and nz: "(a#l) \<noteq> [] \<longrightarrow> last (a#l) \<noteq> 0"
    using assms unfolding list_represents_number_in_base_def by auto
  have "(l \<noteq> []) \<longrightarrow> last l \<noteq> 0"
    using nz by (cases l) auto
  moreover have "\<forall>i<length l. l ! i < q"
    using digits by (cases l) auto
  ultimately show ?thesis
    using q2 unfolding list_represents_number_in_base_def by auto
qed

(* We also prove a converse *)
lemma when_valid_tail_implies_valid:
  assumes L: "list_represents_number_in_base l q"
      and A: "a < q"
      and NZa: "a \<noteq> 0"
  shows "list_represents_number_in_base (a # l) q"
proof -
  from L have q2: "q \<ge> 2"
    and digits_l: "\<forall>i<length l. l ! i < q"
    and nz_l: "l \<noteq> [] \<longrightarrow> last l \<noteq> 0"
    unfolding list_represents_number_in_base_def by auto

  (* all digits of a#l are < q *)
  
  have digits_cons: "\<forall>i<length (a#l). (a#l)!i < q"
    using A digits_l by (auto simp: nth_Cons')

  have no_trail_cons: "(a#l) \<noteq> [] \<longrightarrow> last (a#l) \<noteq> 0"
    using NZa nz_l by (cases l) auto

  show ?thesis
    using q2 digits_cons no_trail_cons
    unfolding list_represents_number_in_base_def by blast
qed

theorem rep_value:
  assumes "list_represents_number_in_base l q"
  shows   "little_endian_rep q (little_endian_value q l) = l"
proof -
  from assms show ?thesis
  proof (induction l)
    case Nil
    then show ?case using little_endian_rep.elims by auto
  next
    case (Cons a l)
    from Cons.prems have q2: "q \<ge> 2"
      and digits: "\<forall>i<length (a#l). (a#l)!i < q"
      and no_trail: "a#l \<noteq> [] \<longrightarrow> last (a#l) \<noteq> 0"
      unfolding list_represents_number_in_base_def by auto
    have a_lt_q: "a < q"
      using digits by auto
    have valid_l: "list_represents_number_in_base l q"
      using valid_tail[OF Cons.prems] .
    have IH: "little_endian_rep q (little_endian_value q l) = l"
      using Cons.IH valid_l by blast
  
    let ?v = "little_endian_value q l"
    let ?m = "a + q * ?v"
  
    have m_mod: "?m mod q = a" by (simp add: a_lt_q)
  
    have m_div: "?m div q = ?v"
    proof -
      have "q * ?v + a = ( ?m div q) * q + (?m mod q)" by (metis add.commute div_mod_decomp)
      hence "q * ?v + a = ( ?m div q) * q + a" using m_mod by presburger
      hence "q * ?v = ( ?m div q) * q" by simp
      with q2 show ?thesis by (simp add: mult_right_cancel)
    qed
  
    have m_pos: "?m \<noteq> 0"
    proof
      assume "?m = 0"
      hence "a = 0" and "?v = 0" using q2 by simp_all
      then have "l = []"
        using valid_l unfolding list_represents_number_in_base_def by (metis Cons.IH little_endian_rep.elims nat.distinct(1) valid_l)
      with no_trail \<open>a = 0\<close> show False by simp
    qed
  
    have "little_endian_rep q (little_endian_value q (a # l))
            = little_endian_rep q ?m" by simp
    also from q2 m_pos have "... = (?m mod q) # little_endian_rep q (?m div q)"  by (smt (verit, ccfv_SIG) lessI linorder_not_less little_endian_rep.elims numeral_2_eq_2 zero_less_Suc)
    also have "... = a # little_endian_rep q ?v" using m_div m_mod by auto
    also have "... = a # l" by (simp add: IH)
    finally show ?case .
  qed
qed

text \<open>
  Now, we prove that this is a bijection between numbers and valid lists  
\<close>

lemma little_endian_rep_creates_valid_list:
  assumes "q\<ge>2"
  shows "list_represents_number_in_base (little_endian_rep q n) q"
proof (induction n rule: less_induct)
  case (less n)
  then show ?case
  proof (cases "n=0")
    case True
    have 1: "little_endian_rep q n =little_endian_rep q 0" by (simp add: True)
    have 2: "... = []" by (metis little_endian_rep.simps(1,2,3) not0_implies_Suc)
    have 3: "list_represents_number_in_base [] q" by (simp add: assms list_represents_number_in_base_def)
    show ?thesis using 1 and 2 and 3 by simp    
  next
    case False
    note nonzero_n = this
    have 4: "q\<ge>2" by (simp add: assms)
    have 5: "little_endian_rep q n = (n mod q)#little_endian_rep q (n div q)" using 4
      by (metis False Suc_n_not_le_n le_0_eq little_endian_rep.elims numeral_2_eq_2
          zero_neq_numeral)
    have 6: "list_represents_number_in_base (little_endian_rep q (n div q)) q"
      by (metis "5" div_le_dividend less linorder_neqE_nat not_Cons_self2
          verit_comp_simplify1(3)) 
    have 7: "(n mod q)<q"
      by (metis "5" list.distinct(1) little_endian_rep.simps(1) mod_less_divisor neq0_conv)
    have 8: "last(little_endian_rep q n) \<noteq> 0"
    proof (cases "little_endian_rep q (n div q) = []")
      case True
      have 9: "n div q = 0"
        by (metis "5" One_nat_def True div_by_1 list.distinct(1) little_endian_rep.simps(1,4)
            old.nat.exhaust)
      have 10: "n<q" using 4 9 
        by (metis "7" mod_eq_self_iff_div_eq_0)
      have 11: "n mod q = n" using 10
        by simp
      have 12: "little_endian_rep q n = [n]" using 5 11
        by (simp add: True)
      have 13: "last(little_endian_rep q n) = n" using 12
        by simp
      have 14: "last(little_endian_rep q n) \<noteq> 0" using nonzero_n 13
        by simp
      show ?thesis using 14
        by simp
    next
      case False
      note nonempty_tail = this
      have 15: "last(little_endian_rep q n) = last(little_endian_rep q (n div q))" using nonempty_tail 5
        by simp
      have 16: "last(little_endian_rep q n) \<noteq> 0" using 15 6
        by (simp add: list_represents_number_in_base_def nonempty_tail)
      show ?thesis using 16
        by simp
    qed
    have 17: "(\<forall> i. ( i< length (little_endian_rep q (n div q)) \<longrightarrow> ((little_endian_rep q (n div q))! i <q)) )" using 6 list_represents_number_in_base_def
      by simp
    have 18:  "(\<forall> i. ( i< length (little_endian_rep q n) \<longrightarrow> ((little_endian_rep q n)! i <q)) )" using 5 7 17 by (auto simp: nth_Cons')
    have 19: "(little_endian_rep q n \<noteq> [] \<longrightarrow> (last (little_endian_rep q n))\<noteq>0)" using 8
      by simp
    have 20: "list_represents_number_in_base (little_endian_rep q n) q" using 19 4 8 18 list_represents_number_in_base_def by auto
    show ?thesis using 20 by simp
  qed
qed

theorem numbers_and_valid_lists_in_bijection:
  assumes "q \<ge> 2"
  defines "valid_lists \<equiv> {l. list_represents_number_in_base l q}"
  shows "bij_betw (little_endian_rep q) UNIV valid_lists"
proof (rule bij_betwI[where g = "little_endian_value q"])
  have 1: "\<And>n. n \<in> UNIV \<Longrightarrow> little_endian_rep q n \<in> valid_lists"
    using assms
    by (simp add: valid_lists_def little_endian_rep_creates_valid_list)
  show "little_endian_rep q \<in> UNIV \<rightarrow> valid_lists" using 1 by simp
  show "little_endian_value q \<in> valid_lists \<rightarrow> UNIV" by simp
  show "\<And>x. x \<in> UNIV \<Longrightarrow> little_endian_value q (little_endian_rep q x) = x" using value_rep assms by simp
  show "\<And>y. y \<in> valid_lists \<Longrightarrow> little_endian_rep q (little_endian_value q y) = y" using rep_value assms by auto
qed

text \<open>
  Now, we prove that this bijection takes numbers <q^k to lists of length up to k
\<close>

theorem small_number_goes_to_small_list:
  assumes "q\<ge>2"
  shows "n < q ^ k \<Longrightarrow> length (little_endian_rep q n) \<le> k"
proof (induction k arbitrary:n)
  have q_geq_2: "q\<ge>2" using assms by simp
  case 0
    have 1: "n=0"
    using "0" by auto
    show ?case
    proof
      have 2: "length (little_endian_rep q n) = length (little_endian_rep q 0)" using 1 try
        by simp
      have 3: "length (little_endian_rep q n) = length []" using 2
        by (metis list.size(3) little_endian_rep.simps(1,2,3) nat.exhaust_sel)
      have 4: "length []  = 0" by simp
      have 5: "length (little_endian_rep q n) = 0" using 1 3 4
        by simp
      thus "length (little_endian_rep q n) = 0" using 5 by simp
    qed
next
  case (Suc k)
  have q_geq_2: "q\<ge>2" using assms
    by simp
  have 7: "n < q ^ Suc k" using Suc(2)
    by simp
  show ?case
  proof (cases "n=0")
    case True
    have n_is_zero: "n=0" using True by simp
    have 8: "length (little_endian_rep q n) = 0" using n_is_zero little_endian_rep.simps(2,3)
      by (metis "7" less_not_refl list.size(3) old.nat.exhaust
          power_0_Suc)
    show ?thesis using 8 by simp
  next
    case False
    have n_is_not_zero: "n\<noteq>0" using False by simp
    have 9: "length (little_endian_rep q n) = length ((n mod q) # little_endian_rep q (n div q))" using n_is_not_zero little_endian_rep.simps(3) q_geq_2 
      by (smt (verit) Suc_leD little_endian_rep.elims not_less_eq_eq numeral_2_eq_2)
    have 10: "... = Suc (length (little_endian_rep q (n div q)))" using 9
      by simp
    have 11: "(q^ Suc k) = (q^k)* q" using 7 power_Suc
      by simp
    have 12: "n<(q^k)* q" using 11 7
      by (metis)
    have 13: "(n div q<(q^k))=(n<(q^k)* q)" using q_geq_2 div_less_iff_less_mult try
      by simp
    have 14: "n div q<(q^k)" using 12 13 by simp
    have 15: "length (little_endian_rep q (n div q)) \<le> k" using 14 Suc.IH by auto
    have 16: "length (little_endian_rep q n) \<le> Suc k" using 9 10 15 by simp
    show ?thesis using 16 by simp
  qed
qed

theorem small_list_goes_to_small_number:
  assumes q_valid: "q\<ge>2"
   and list_valid: "list_represents_number_in_base l q"
 shows "(little_endian_value q l) < q ^ (length l)"
  using assms
proof (induction l)

  case Nil
  show ?case using little_endian_value.simps(1) by simp
next
  case (Cons a l)
  show ?case
  proof -
    thm Cons.IH
    thm assms
    thm Cons.prems
    have 1: "list_represents_number_in_base l q" using Cons.prems valid_tail by simp
    have 2: "(little_endian_value q l) \<le> q ^ (length l)-1" using Cons.IH assms 1 by simp
    have 3: "little_endian_value q (a # l) = a + q*(little_endian_value q l)" using little_endian_value.simps by simp
    have 4: "little_endian_value q (a # l) \<le> a + q*(q^(length l)-1)" using 2 3 q_valid by fastforce
    have 5: "a\<le>q-1" using Cons.prems list_represents_number_in_base_def by auto
    have 6: "little_endian_value q (a # l) \<le> q-1 + q*(q^(length l)-1)" using 4 5
      by linarith
    have 7: "q-1 + q*(q^(length l)-1) =  q^(length l+1)-1" using diff_mult_distrib2 q_valid by simp
    have 8: "length (a#l) = length l+1" by simp
    show ?case using 7 8 by (metis "6" Nat.le_diff_conv2 add_leD2 less_iff_succ_less_eq one_add_one one_le_power q_valid)
  qed
qed

theorem small_numbers_and_small_valid_lists_in_bijection:
  assumes q_valid:"q \<ge> 2"
    and k_valid: "k\<ge>1"
  defines "valid_lists_of_length_k \<equiv> {l. list_represents_number_in_base l q \<and> length l \<le> k}"
  and "numbers_up_to_power_k \<equiv> {n. n<q^k}"
shows "bij_betw (little_endian_rep q) numbers_up_to_power_k valid_lists_of_length_k"
proof (rule bij_betwI[where g = "little_endian_value q"])
  have 1: "\<And>n. n \<in> numbers_up_to_power_k \<Longrightarrow> little_endian_rep q n \<in> valid_lists_of_length_k"
    using assms and small_number_goes_to_small_list and little_endian_rep_creates_valid_list by simp
  show "little_endian_rep q \<in> numbers_up_to_power_k \<rightarrow> valid_lists_of_length_k" using 1 try
    by simp
  have 2: "\<And>l. l \<in> valid_lists_of_length_k \<Longrightarrow> little_endian_value q l \<in> numbers_up_to_power_k" proof - 
    fix l
    assume l_valid: "l \<in> valid_lists_of_length_k"
    have 3: "length l \<le> k" using l_valid valid_lists_of_length_k_def by simp
    have 4: "(little_endian_value q l) < q ^ (length l)" using l_valid and small_list_goes_to_small_number and q_valid and valid_lists_of_length_k_def by simp
    have 5: "q ^ (length l) \<le> q ^ k" using 3 and q_valid by simp
    have 6: "(little_endian_value q l) < q ^ k" using 4 and 5 by simp
    show "little_endian_value q l \<in> numbers_up_to_power_k" using 6  numbers_up_to_power_k_def by auto
  qed
  show "little_endian_value q \<in> valid_lists_of_length_k \<rightarrow> numbers_up_to_power_k" using 2 by auto
  show "\<And>x. x \<in> numbers_up_to_power_k \<Longrightarrow> little_endian_value q (little_endian_rep q x) = x" using assms and value_rep by simp
  show "\<And>y. y \<in> valid_lists_of_length_k \<Longrightarrow> little_endian_rep q (little_endian_value q y) = y" using assms and rep_value by simp
qed
    
